<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Dad Chat Control</title>

<script src="https://unpkg.com/mqtt/dist/mqtt.min.js"></script>

<style>
body{
font-family:Arial;
background:#111;
color:white;
max-width:500px;
margin:auto;
padding:20px;
}

input,textarea{
width:100%;
padding:10px;
margin-top:5px;
margin-bottom:15px;
font-size:16px;
}

button{
width:100%;
padding:15px;
font-size:18px;
background:#2ecc71;
border:none;
color:white;
border-radius:6px;
}

#responses{
background:#222;
padding:10px;
height:200px;
overflow:auto;
border-radius:6px;
}
</style>
</head>

<body>

<h2>Dad Chat</h2>

<label>Title</label>
<input id="title">

<label>Message</label>
<textarea id="message"></textarea>

<label>Button 1</label>
<input id="b1">

<label>Button 2</label>
<input id="b2">

<label>Button 3</label>
<input id="b3">

<button onclick="send()">SEND</button>

<h3>Responses</h3>
<div id="responses"></div>

<script>

const client = mqtt.connect(
"wss://b1dcdceb082d4443873bb186cd006f90.s1.eu.hivemq.cloud:8884/mqtt",
{
username: "MLDS_CHAT2",
password: "Tonka123"
});

const room = "dadchat/room1";

client.on("connect", ()=>{

console.log("MQTT connected");

client.subscribe(room+"/response");

});

client.on("message",(topic,msg)=>{

if(topic === room+"/response")
{
let log = document.getElementById("responses");

let txt = msg.toString();

let div = document.createElement("div");

div.innerText = txt;

log.prepend(div);
}

});

function send(){

let title = document.getElementById("title").value;
let msg = document.getElementById("message").value;

let b1 = document.getElementById("b1").value;
let b2 = document.getElementById("b2").value;
let b3 = document.getElementById("b3").value;

client.publish(room+"/title",title);
client.publish(room+"/message",msg);

let buttons = b1+"|"+b2+"|"+b3;

client.publish(room+"/buttons",buttons);

}

</script>

</body>
</html>
